{
  "name": "appfolio-maintenance-ai-assistant",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @appfolio-ai/web",
    "dev:web": "npm run dev -w @appfolio-ai/web",
    "dev:api": "npm run dev -w @appfolio-ai/api",
    "build": "npm run build -w @appfolio-ai/core && npm run build -w @appfolio-ai/api && npm run build -w @appfolio-ai/web",
    "build:web": "npm run build -w @appfolio-ai/web",
    "build:api": "npm run build -w @appfolio-ai/api",
    "typecheck": "npm run typecheck -w @appfolio-ai/core && npm run typecheck -w @appfolio-ai/api && npm run typecheck -w @appfolio-ai/web",
    "lint": "npm run lint -w @appfolio-ai/web"
  },
  "dependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.3.0",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  }
}
